# This script (`before.sh.erb`) is sourced directly into the main Bash script
# that is run when the batch job starts up. It is called before the `script.sh`
# is forked off into a separate process.

export DIRNAME="<%= context.dirname %>"
export BC_EMAIL_ON_STARTED="<%= context.bc_email_on_started %>"
export ACCOUNT="<%= context.account %>"
export CREATED_AT="<%= session.created_at %>"
export WORKINGDIR=/nesi/nobackup/${ACCOUNT}/${DIRNAME}
export INPUT_PATH=${WORKINGDIR}/input
export OUTPUT=${WORKINGDIR}/output

export FASTA_FILE="${INPUT_PATH}/input.fasta"
export JSON_FILE="${INPUT_PATH}/input.json"

#source "alphafold_env.sh"

mkdir -p "${WORKINGDIR}" "${INPUT_PATH}" "${OUTPUT}"

# Prepare input sequence and save to FASTA file
echo '<%= context.protein_sequence.to_s %>' > "${FASTA_FILE}"
echo "Debug: Created FASTA file at ${FASTA_FILE}"